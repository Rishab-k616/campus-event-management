{
  "expo": {
    "name": "Campus Event Manager",
    "slug": "campus-event-manager",
    "version": "1.0.0",
    "scheme": "campusevents",
    "orientation": "portrait",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "plugins": [
      "expo-router",
      "expo-font"
    ],
    "ios": {
