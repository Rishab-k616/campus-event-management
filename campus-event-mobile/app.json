      "bundleIdentifier": "com.campusevents.manager"
    },
    "android": {
      "package": "com.campusevents.manager",
      "adaptiveIcon": {
        "backgroundColor": "#172554"
      }
    },
    "extra": {
      "router": {
        "origin": false
      },
      "eas": {
        "projectId": "93d257f9-9f90-49ef-85c1-5b0d9601e7dc"
      }
    }
  }
}
